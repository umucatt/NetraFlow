{
  "name": "netraflow",
  "version": "0.9.9",
  "private": true,
  "license": "GPL-3.0-only",
  "productName": "NetraFlow",
  "description": "资产变化记录工具",
  "type": "module",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.netraflow.app",
    "productName": "NetraFlow",
    "asar": true,
    "directories": {
      "output": "release/installer"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "package.json",
      "!**/netraflow.icns",
      "!**/userData/**",
      "!**/userdata/**",
      "!**/.demo/**",
      "!**/runtime/**",
      "!**/logs/**",
      "!**/Local Storage/**",
      "!**/IndexedDB/**",
      "!**/Cache/**",
      "!**/Code Cache/**",
      "!**/GPUCache/**",
      "!**/Session Storage/**",
      "!**/Preferences",
      "!**/Local State",
      "!**/blob_storage/**",
      "!**/DawnCache/**",
      "!**/DawnWebGPUCache/**",
      "!**/Network/**",
      "!**/Shared Dictionary/**",
      "!release/**",
      "!**/AppData/**"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "afterPack": "scripts/after-pack-installer.mjs",
    "extraFiles": [
      {
        "from": "build/licenses",
        "to": "licenses",
        "filter": [
          "LICENSE.NotoSansCJK.txt",
          "LICENSE.NotoSansSymbols2.txt"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "public/icons/netraflow.icns",
      "extendInfo": {
        "NSHumanReadableCopyright": ""
      },
      "artifactName": "NetraFlow_${version}_${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/linux",
      "category": "Utility",
      "desktop": {
        "entry": {
          "StartupWMClass": "NetraFlow",
          "Terminal": "false"
        }
      },
      "artifactName": "NetraFlow_${version}_${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/netraflow.ico",
      "artifactName": "NetraFlow_${version}_${arch}_Setup.${ext}",
      "executableName": "NetraFlow",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "packElevateHelper": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "shortcutName": "NetraFlow",
      "uninstallDisplayName": "NetraFlow",
      "installerIcon": "public/icons/netraflow.ico",
      "uninstallerIcon": "public/icons/netraflow.ico",
      "include": "build/installer/installer.nsh",
      "differentialPackage": false
    }
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:electron": "npm run clean:electron && tsc -p tsconfig.node.json && wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .",
    "clean:electron": "node -e \"require('node:fs').rmSync('dist-electron', { recursive: true, force: true })\"",
    "build": "tsc --noEmit -p tsconfig.json && vite build && npm run clean:electron && tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "node scripts/run-tests.mjs",
    "release:check": "node scripts/check-release.mjs",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "start": "npm run build && electron .",
    "clean:release": "node scripts/clean-release.mjs",
    "dist:installer": "node scripts/package-installer.mjs",
    "dist:portable": "node scripts/package-portable.mjs",
    "dist:mac": "node scripts/package-dmg.mjs",
    "dist:linux": "node scripts/package-appimage.mjs",
    "dist:deb": "node scripts/package-deb.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:windows-icon": "node scripts/generate-windows-icon.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1"
  }
}
