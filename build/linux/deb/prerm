#!/bin/sh
set -e

case "${1:-}" in
  remove|deconfigure) ;;
  *) exit 0 ;;
esac

enabled_file=/sys/module/apparmor/parameters/enabled
profile=/etc/apparmor.d/opt.NetraFlow.netraflow

if [ ! -r "$enabled_file" ] || [ "$(head -c 1 "$enabled_file" 2>/dev/null || true)" != "Y" ]; then
  exit 0
fi

if ! command -v apparmor_parser >/dev/null 2>&1; then
  exit 0
fi

# An already-unloaded profile must not prevent package removal.
apparmor_parser --remove "$profile" 2>/dev/null || true
